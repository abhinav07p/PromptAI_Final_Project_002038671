# TrialMatch AI — Environment Configuration
# Copy to .env and fill in your values

# ── LLM API Keys (only for API Mode) ──
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Ollama (only for Ollama Mode) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Government APIs (optional) ──
OPENFDA_API_KEY=
NCI_API_KEY=

# ── Vector Store ──
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=trial_eligibility

# ── Whisper ──
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# ── App ──
DEFAULT_MODE=demo
LOG_LEVEL=INFO
