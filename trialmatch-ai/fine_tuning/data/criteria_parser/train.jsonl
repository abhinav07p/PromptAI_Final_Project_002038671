{"input": "Patients must be at least 18 years of age.", "output": {"rules": [{"field": "demographics.age", "operator": ">=", "value": 18, "type": "numerical_range"}], "criteria_type": "inclusion", "complexity": "simple"}}
{"input": "ECOG performance status of 0 or 1.", "output": {"rules": [{"field": "ECOG_performance_status", "operator": "in", "value": [0, 1], "type": "numerical_range"}], "criteria_type": "inclusion", "complexity": "simple"}}
{"input": "Documented EGFR mutation (exon 19 deletion or exon 21 L858R).", "output": {"rules": [{"field": "biomarkers.EGFR", "operator": "in", "value": ["Exon 19 deletion", "L858R"], "type": "biomarker_required"}], "criteria_type": "inclusion", "complexity": "simple"}}
{"input": "Adequate hematologic function: ANC >= 1500/uL, platelets >= 100000/uL, hemoglobin >= 9.0 g/dL.", "output": {"rules": [{"field": "lab_values.ANC", "operator": ">=", "value": 1500, "type": "lab_threshold"}, {"field": "lab_values.platelets", "operator": ">=", "value": 100000, "type": "lab_threshold"}, {"field": "lab_values.hemoglobin", "operator": ">=", "value": 9.0, "type": "lab_threshold"}], "criteria_type": "inclusion", "complexity": "compound"}}
{"input": "No prior anti-PD-1, anti-PD-L1, or anti-CTLA-4 antibody.", "output": {"rules": [{"field": "prior_therapies", "operator": "not_includes_class", "value": ["anti-PD-1", "anti-PD-L1", "anti-CTLA-4"], "type": "medication_exclusion"}], "criteria_type": "exclusion", "complexity": "simple"}}
{"input": "Total bilirubin <= 1.5 x ULN OR direct bilirubin <= ULN if total bilirubin > 1.5 x ULN.", "output": {"rules": [{"field": "lab_values.total_bilirubin", "operator": "<=", "value": "1.5x_ULN", "type": "lab_threshold", "logic": "OR", "alt": {"field": "direct_bilirubin", "operator": "<=", "value": "ULN"}}], "criteria_type": "inclusion", "complexity": "conditional"}}
{"input": "No concurrent use of strong CYP3A4 inhibitors or inducers.", "output": {"rules": [{"field": "current_medications", "operator": "not_includes_class", "value": ["strong_CYP3A4_inhibitor", "strong_CYP3A4_inducer"], "requires_api": "openfda", "type": "medication_exclusion"}], "criteria_type": "exclusion", "complexity": "simple"}}
{"input": "LVEF >= 50% by echocardiogram within 4 weeks.", "output": {"rules": [{"field": "lab_values.LVEF", "operator": ">=", "value": 50, "unit": "%", "temporal": "within_28_days", "type": "lab_threshold"}], "criteria_type": "inclusion", "complexity": "compound"}}
{"input": "No known active CNS metastases. Previously treated brain mets allowed if stable >= 4 weeks.", "output": {"rules": [{"field": "diagnosis.metastatic_sites", "operator": "not_includes_active", "value": "CNS", "type": "condition_excluded", "exception": "treated and stable >= 28 days"}], "criteria_type": "exclusion", "complexity": "conditional"}}
{"input": "Patients with active autoimmune disease requiring systemic treatment within 3 months excluded.", "output": {"rules": [{"field": "comorbidities", "operator": "not_includes", "value": "active autoimmune disease", "qualifier": "systemic treatment within 90 days", "type": "condition_excluded"}], "criteria_type": "exclusion", "complexity": "compound"}}
{"input": "Stage IIIB or IV not amenable to curative surgery or radiation.", "output": {"rules": [{"field": "diagnosis.stage", "operator": "in", "value": ["IIIB", "IV"], "type": "numerical_range"}, {"field": "clinical_assessment", "value": "not amenable to curative intent", "requires_manual": true, "type": "condition_required"}], "criteria_type": "inclusion", "complexity": "compound"}}
{"input": "Histologically confirmed non-small cell lung cancer.", "output": {"rules": [{"field": "diagnosis.condition", "operator": "==", "value": "Non-Small Cell Lung Cancer", "type": "condition_required"}], "criteria_type": "inclusion", "complexity": "simple"}}
